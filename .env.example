# ─── App ─────────────────────────────────────────────────────────────────────
# URL de l'API vue par le NAVIGATEUR (compilée dans le bundle web au BUILD).
#   - Local / HTTP test  : http://localhost:4000
#   - VPS public (HTTPS)  : https://<API_DOMAIN>  (ex. https://api.exemple.com)
NEXT_PUBLIC_API_URL=http://localhost:4000

# Optionnel : worker de rendu séparé via BullMQ. Vide = rendu in-process (défaut).
# REDIS_URL=redis://localhost:6379

# Optionnel : répertoire de stockage local (médias, renders, uploads).
# Défaut = apps/api/data (monté sur le volume cosyl-data en prod).
# COSYL_DATA_DIR=

# ─── HTTPS (uniquement avec docker-compose.tls.yml + Caddy) ───────────────────
# Deux sous-domaines pointés (enregistrement A) vers l'IP du serveur.
APP_DOMAIN=
API_DOMAIN=

# ─── Supabase ─────────────────────────────────────────────────────────────────
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ─── AIML API (clé unique → LLM + images + vidéo + voix + musique) ────────────
# Obtenir la clé : https://aimlapi.com
AIML_API_KEY=

# ─── Fallback : clés directes (optionnel, si pas d'AIML_API_KEY) ──────────────
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
