{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://content-gen.local/production/schemas/03-image-prompt.schema.json",
  "title": "Agent 3 Image Prompt Output",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "agent_metadata",
    "scene_id",
    "main_prompt",
    "negative_prompt",
    "visual_anchors",
    "continuity_indices"
  ],
  "properties": {
    "agent_metadata": {
      "allOf": [
        {
          "$ref": "shared.schema.json#/$defs/agentMetadata"
        },
        {
          "properties": {
            "stage": {
              "const": "image-prompts"
            },
            "role": {
              "const": "Agent 3"
            }
          }
        }
      ]
    },
    "scene_id": {
      "$ref": "shared.schema.json#/$defs/nonEmptyString"
    },
    "main_prompt": {
      "$ref": "shared.schema.json#/$defs/nonEmptyString"
    },
    "negative_prompt": {
      "type": "string"
    },
    "visual_anchors": {
      "$ref": "shared.schema.json#/$defs/stringArray"
    },
    "continuity_indices": {
      "type": "object",
      "properties": {
        "lighting": { "type": "string" },
        "environment_anchor_objects": { "type": "string" },
        "core_subject": { "type": "string" }
      },
      "required": ["lighting", "environment_anchor_objects", "core_subject"]
    }
  }
}
