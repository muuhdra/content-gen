{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://content-gen.local/production/schemas/05-motion-video.schema.json",
  "title": "Agent 5 Motion Video Output",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "agent_metadata",
    "scene_id",
    "source_context",
    "scene_analysis",
    "motion_direction",
    "cinematic_constraints",
    "final_video_prompt"
  ],
  "properties": {
    "agent_metadata": {
      "allOf": [
        {
          "$ref": "shared.schema.json#/$defs/agentMetadata"
        },
        {
          "properties": {
            "stage": {
              "const": "motion-video"
            },
            "role": {
              "const": "Agent 5"
            }
          }
        }
      ]
    },
    "scene_id": {
      "$ref": "shared.schema.json#/$defs/nonEmptyString"
    },
    "source_context": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "script_excerpt",
        "source_image_prompt",
        "approved_image_reference"
      ],
      "properties": {
        "script_excerpt": {
          "$ref": "shared.schema.json#/$defs/nonEmptyString"
        },
        "source_image_prompt": {
          "$ref": "shared.schema.json#/$defs/nonEmptyString"
        },
        "approved_image_reference": {
          "$ref": "shared.schema.json#/$defs/nonEmptyString"
        }
      }
    },
    "scene_analysis": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "narrative_purpose",
        "emotional_tone",
        "main_subject",
        "subject_action",
        "environment",
        "visual_style",
        "energy_level"
      ],
      "properties": {
        "narrative_purpose": {
          "$ref": "shared.schema.json#/$defs/nonEmptyString"
        },
        "emotional_tone": {
          "$ref": "shared.schema.json#/$defs/nonEmptyString"
        },
        "main_subject": {
          "$ref": "shared.schema.json#/$defs/nonEmptyString"
        },
        "subject_action": {
          "$ref": "shared.schema.json#/$defs/nonEmptyString"
        },
        "environment": {
          "$ref": "shared.schema.json#/$defs/nonEmptyString"
        },
        "visual_style": {
          "$ref": "shared.schema.json#/$defs/nonEmptyString"
        },
        "energy_level": {
          "$ref": "shared.schema.json#/$defs/nonEmptyString"
        }
      }
    },
    "motion_direction": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "camera_movement",
        "subject_motion",
        "environment_motion"
      ],
      "properties": {
        "camera_movement": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "type",
            "speed",
            "intensity",
            "direction",
            "purpose"
          ],
          "properties": {
            "type": {
              "$ref": "shared.schema.json#/$defs/nonEmptyString"
            },
            "speed": {
              "$ref": "shared.schema.json#/$defs/nonEmptyString"
            },
            "intensity": {
              "$ref": "shared.schema.json#/$defs/motionIntensity"
            },
            "direction": {
              "$ref": "shared.schema.json#/$defs/nonEmptyString"
            },
            "purpose": {
              "$ref": "shared.schema.json#/$defs/nonEmptyString"
            }
          }
        },
        "subject_motion": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "type",
            "intensity",
            "details"
          ],
          "properties": {
            "type": {
              "$ref": "shared.schema.json#/$defs/nonEmptyString"
            },
            "intensity": {
              "$ref": "shared.schema.json#/$defs/motionIntensity"
            },
            "details": {
              "$ref": "shared.schema.json#/$defs/nonEmptyString"
            }
          }
        },
        "environment_motion": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "type",
            "intensity",
            "details"
          ],
          "properties": {
            "type": {
              "$ref": "shared.schema.json#/$defs/nonEmptyString"
            },
            "intensity": {
              "$ref": "shared.schema.json#/$defs/motionIntensity"
            },
            "details": {
              "$ref": "shared.schema.json#/$defs/nonEmptyString"
            }
          }
        }
      }
    },
    "cinematic_constraints": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "preserve",
        "avoid"
      ],
      "properties": {
        "preserve": {
          "$ref": "shared.schema.json#/$defs/stringArray"
        },
        "avoid": {
          "$ref": "shared.schema.json#/$defs/stringArray"
        }
      }
    },
    "final_video_prompt": {
      "$ref": "shared.schema.json#/$defs/nonEmptyString"
    },
    "negative_prompt": {
      "type": "string"
    }
  }
}
